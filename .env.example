# Anthropic API key for Claude Agent SDK
ANTHROPIC_BASE_URL="https://openrouter.ai/api"
ANTHROPIC_AUTH_TOKEN=your-openrouter-api-key
ANTHROPIC_API_KEY="" # Important: Must be explicitly empty
ANTHROPIC_DEFAULT_SONNET_MODEL=""
ANTHROPIC_DEFAULT_OPUS_MODEL=""
ANTHROPIC_DEFAULT_HAIKU_MODEL=""
CLAUDE_CODE_SUBAGENT_MODEL=""
ENABLE_EXPERIMENTAL_MCP_CLI="true"

# GitHub Personal Access Token (for repo, issues, PRs, actions)
GITHUB_PAT=ghp_...

# Provider Selection (google or microsoft)
TODO_PROVIDER=google
CALENDAR_PROVIDER=google

# Voice Provider Selection
TTS_PROVIDER=elevenlabs        # elevenlabs, fal, replicate, openai, kokoro, deepgram
STT_PROVIDER=groq              # groq, fal, replicate, openai, deepgram, kokoro

# Google Tasks (OAuth2 credentials)
GOOGLE_TASKS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_TASKS_CLIENT_SECRET=your-client-secret
GOOGLE_TASKS_REFRESH_TOKEN=your-refresh-token

# Google Calendar (OAuth2 credentials - can share with Tasks)
GOOGLE_CALENDAR_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your-client-secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your-refresh-token

# Microsoft To Do & Outlook Calendar (OAuth2 credentials)
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_REFRESH_TOKEN=your-refresh-token

# Vercel (API token from vercel.com/account/tokens)
VERCEL_TOKEN=your-vercel-token

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Brave Search (API key from brave.com/search/api)
BRAVE_API_KEY=your-brave-api-key

# Voice/TTS/STT Providers
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-default-voice-id
FAL_API_KEY=your-fal-api-key
REPLICATE_API_TOKEN=your-replicate-token
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
DEEPGRAM_API_KEY=your-deepgram-api-key

# Kokoro TTS (local or hosted)
KOKORO_API_URL=http://localhost:8880
KOKORO_ENABLED=true

# WhatsApp
WHATSAPP_ALLOWED_DMS=+1234567890
WHATSAPP_ALLOWED_GROUPS=*

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALLOWED_DMS=*

# iMessage (macOS only)
IMESSAGE_ALLOWED_DMS=+1234567890
IMESSAGE_ALLOWED_GROUPS=